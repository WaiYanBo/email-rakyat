---
import SettingsView from '../../components/SettingsView';
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Settings - Staff Portal">
  <div class="space-y-6 md:space-y-8 animate-page-transition pt-12 md:pt-0">
    <div class="flex flex-col gap-2">
      <h1 class="text-2xl md:text-3xl font-black uppercase tracking-widest text-teal-900 dark:text-white">
        Account Settings
      </h1>
      <p class="text-xs md:text-sm text-teal-700 dark:text-gray-400">
        Manage your profile settings and account security
      </p>
    </div>

    <SettingsView client:only="react" />
  </div>
</DashboardLayout>

