---
import PortalSidebar from '../components/PortalSidebar';
import Layout from './Layout.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<Layout title={title}>
  <!-- Sidebar component is fixed positioned -->
  <PortalSidebar client:only="react" />
  
  <!-- Main Content - Shifted right on desktop to account for fixed sidebar -->
  <main class="min-h-[100dvh] md:ml-64 pb-[calc(5rem+env(safe-area-inset-bottom))] px-4 md:px-8 py-12 md:py-12 animate-fade-in transition-all duration-300">
    <slot />
  </main>
</Layout>

<style>
  :global(.scrollbar-thin::-webkit-scrollbar) {
    width: 6px;
  }
  
  :global(.scrollbar-thin::-webkit-scrollbar-track) {
    background: transparent;
  }
  
  :global(.scrollbar-thin::-webkit-scrollbar-thumb) {
    background: rgb(107, 114, 128);
    border-radius: 3px;
  }
  
  :global(.dark .scrollbar-thin::-webkit-scrollbar-thumb) {
    background: rgb(55, 65, 81);
  }
</style>
