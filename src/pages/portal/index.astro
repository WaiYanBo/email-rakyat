---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ExecutiveOverview from '../../components/ExecutiveOverview';
import ClockInClockOut from '../../components/ClockInClockOut';
import AttendanceView from '../../components/AttendanceView';
import AttendanceAnalyticsSample from '../../components/AttendanceAnalyticsSample';
---

<DashboardLayout title="Overview - Staff Portal">
  <div class="flex flex-col gap-8">
    <div>
      <ExecutiveOverview client:only="react" />
    </div>
    <div>
      <ClockInClockOut client:only="react" />
    </div>
    <div>
      <AttendanceAnalyticsSample client:only="react" />
    </div>
    <div>
      <AttendanceView client:only="react" personalOnly={true} />
    </div>
  </div>
</DashboardLayout>
