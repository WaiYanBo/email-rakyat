---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import FileDriveView from '../../components/FileDriveView';
---

<DashboardLayout title="Pemacu Syarikat - Staff Portal">
  <div class="space-y-6 md:space-y-8 animate-page-transition pt-12 md:pt-0 h-full flex flex-col">
    <div class="flex flex-col gap-2">
      <h1 class="text-2xl md:text-3xl font-black uppercase tracking-widest text-teal-900 dark:text-white">
        Company Drive
      </h1>
      <p class="text-xs md:text-sm text-teal-700 dark:text-gray-400">
        Secure cloud storage for company files and documents
      </p>
    </div>

    <FileDriveView client:only="react" />
  </div>
</DashboardLayout>
