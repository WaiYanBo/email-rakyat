---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import ReportsView from '../../components/ReportsView';
---

<DashboardLayout title="Reports - Staff Portal">
  <div class="space-y-4 md:space-y-6 animate-page-transition pt-12 md:pt-0">
    <div class="flex flex-col gap-2">
      <h1 class="text-2xl md:text-3xl font-black uppercase tracking-widest text-teal-900 dark:text-white">
        Reports and Analytics
      </h1>
      <p class="text-xs md:text-sm text-teal-700 dark:text-gray-400">
        View detailed reports and system analytics
      </p>
    </div>

    <ReportsView client:load />
  </div>
</DashboardLayout>