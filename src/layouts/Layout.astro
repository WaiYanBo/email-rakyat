---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SEO from '../components/SEO.astro';
import '../styles/global.css';
import '@fontsource/nunito-sans/400.css';
import '@fontsource/nunito-sans/700.css';
import '@fontsource/nunito-sans/900.css';

interface Props {
    title?: string;
    description?: string;
    image?: string;
    noindex?: boolean;
}

const { 
    title = "Bantuan Mangsa Ah Long & Hutang | Email Rakyat | Report Loan Shark & Debt Collector", 
    description = "Portal rasmi aduan dan bantuan mangsa Ah Long & Scam. Kami melindungi privasi dan hak anda.",
    image,
    noindex = false 
} = Astro.props;
---

<!doctype html>
<html lang="ms">
    <head>
        <meta charset="utf-8" />
        <SEO title={title} description={description} noindex={noindex} />
        <link rel="icon" href="/logo-v2.png" sizes="any" />
        <link rel="icon" type="image/svg+xml" href="/logo-v2.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta name="google-site-verification" content="pL6VVDBvT7AFJsF-iNber0pk7W-Sm1ooRfdVehPlAy8" />
        
        <script async src="https://www.googletagmanager.com/gtag/js?id=AW-17941357588"></script>
        <script is:inline>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'AW-17941357588');

        function gtag_report_conversion() {
            gtag('event', 'conversion', {
                'send_to': 'AW-17941357588/PFRMCLyU0_YbEJTIjetC'
            });
            return true; 
        }
        </script>

        <slot name="head" />

        <script src="/scripts/analytics.js" defer></script>
    </head>
    
    <body class="bg-gray-900 text-white font-sans min-h-screen flex flex-col">
        <Navbar />
        
        <main class="flex-grow">
            <slot />
        </main>
        
        <div id="cookie-banner" class="fixed bottom-0 left-0 w-full bg-gray-900 border-t border-gray-700 p-4 z-[100] shadow-[0_-10px_30px_rgba(0,0,0,0.5)] flex flex-col md:flex-row justify-between items-center gap-4 hidden">
            <div class="text-sm text-gray-300 flex-1">
                <p><strong>Privasi & Analitik Tanpa Nama:</strong> Kami merekodkan data pelayaran secara awanama (tanpa menyimpan Alamat IP) untuk menambah baik platform ini. Anda boleh mengurus pilihan penjejakan tambahan.</p>
            </div>
            <div class="flex flex-col sm:flex-row gap-3 shrink-0 w-full md:w-auto">
                <button id="btn-manage" class="px-6 py-2 rounded bg-gray-700 hover:bg-gray-600 text-white font-semibold transition w-full sm:w-auto">Urus Pilihan</button>
                <button id="btn-accept-all" class="px-6 py-2 rounded bg-green-500 hover:bg-green-600 text-white font-bold transition w-full sm:w-auto">Terima Semua</button>
            </div>
        </div>
        
        <div id="cookie-modal" class="fixed inset-0 z-[110] bg-black/80 backdrop-blur-sm items-center justify-center hidden flex">
            <div class="bg-gray-800 border border-gray-700 rounded-lg p-6 max-w-md w-full mx-4 shadow-2xl">
                <h3 class="text-xl font-bold text-white mb-4">Tetapan Privasi & Analitik</h3>
                
                <div class="space-y-4 mb-6">
                    <div class="flex items-start justify-between p-3 bg-gray-900 rounded border border-gray-700">
                        <div class="pr-4">
                            <h4 class="text-white font-semibold text-sm">Analitik Tanpa Nama (Wajib)</h4>
                            <p class="text-xs text-gray-400 mt-1">Merekodkan masa skrin dan halaman yang dilawati menggunakan ID sementara. Ini mandatori untuk kami memahami isu rakyat yang paling mendesak. <strong>Kami berjanji TIADA Alamat IP atau data peribadi dikumpul.</strong></p>
                        </div>
                        <input type="checkbox" checked disabled class="mt-1 w-5 h-5 accent-green-500 opacity-50 cursor-not-allowed" aria-label="Wajib">
                    </div>
        
                    <div class="flex items-start justify-between p-3 bg-gray-900 rounded border border-gray-700">
                        <div class="pr-4">
                            <h4 class="text-white font-semibold text-sm">Analitik Peranti (Pilihan)</h4>
                            <p class="text-xs text-gray-400 mt-1">Membenarkan kami merekod jenis peranti anda (Telefon/Komputer) semata-mata untuk membantu menambah baik susun atur paparan (UI).</p>
                        </div>
                        <input type="checkbox" id="toggle-device" class="mt-1 w-5 h-5 accent-green-500 cursor-pointer" aria-label="Pilihan Peranti">
                    </div>
                </div>
        
                <button id="btn-save-prefs" class="w-full px-4 py-3 rounded bg-green-500 hover:bg-green-600 text-white font-bold transition">Simpan Pilihan</button>
            </div>
        </div>
        
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const banner = document.getElementById("cookie-banner");
                const modal = document.getElementById("cookie-modal");
                
                const btnManage = document.getElementById("btn-manage");
                const btnAcceptAll = document.getElementById("btn-accept-all");
                const btnSavePrefs = document.getElementById("btn-save-prefs");
                const toggleDevice = document.getElementById("toggle-device");
        
                // 1. Check if preferences exist
                const savedPrefs = localStorage.getItem("cookie_preferences");
                
                // Show banner if no choice has been made
                if (!savedPrefs) {
                    banner.classList.remove("hidden");
                }
        
                // 2. Open Settings Modal
                btnManage.addEventListener("click", () => {
                    modal.classList.remove("hidden");
                    toggleDevice.checked = savedPrefs ? JSON.parse(savedPrefs).device : false;
                });
        
                // 3. Accept All Button
                btnAcceptAll.addEventListener("click", () => {
                    localStorage.setItem("cookie_preferences", JSON.stringify({ essential: true, device: true }));
                    banner.classList.add("hidden");
                    window.location.reload(); 
                });
        
                // 4. Save Custom Preferences Button
                btnSavePrefs.addEventListener("click", () => {
                    localStorage.setItem("cookie_preferences", JSON.stringify({ essential: true, device: toggleDevice.checked }));
                    modal.classList.add("hidden");
                    banner.classList.add("hidden");
                    window.location.reload(); 
                });
            });
        </script>
        
        <Footer />

        <a 
            href="https://wa.me/+601163623282" 
            target="_blank"
            onclick="gtag_report_conversion();"
            class="fixed bottom-6 right-6 z-50 flex items-center gap-3 bg-green-500 hover:bg-green-600 text-white px-5 py-4 rounded-full shadow-[0_0_20px_rgba(34,197,94,0.5)] transition-all hover:scale-110 group animate-bounce-slow"
            aria-label="Contact on WhatsApp"
        >
            <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.008-.57-.008-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.304-5.292c0-5.448 4.435-9.88 9.884-9.88 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            <div class="flex flex-col text-left">
                <span class="text-[10px] uppercase font-bold text-green-100 tracking-wider">Perlukan Bantuan?</span>
                <span class="text-sm font-black leading-none">WHATSAPP KAMI</span>
            </div>
        </a>
    </body>
</html>