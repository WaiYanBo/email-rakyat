---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---

<DashboardLayout title="Settings - Staff Portal">
  <div class="space-y-4 md:space-y-6 animate-page-transition pt-12 md:pt-0">
    <div class="flex flex-col gap-2">
      <h1 class="text-2xl md:text-3xl font-black uppercase tracking-widest text-teal-900 dark:text-white">
        Account Settings
      </h1>
      <p class="text-xs md:text-sm text-teal-700 dark:text-gray-400">
        Manage your profile settings and account security
      </p>
    </div>

    <div class="p-6 md:p-12 rounded-xl md:rounded-2xl bg-white dark:bg-gray-900/50 border border-teal-200 dark:border-gray-700 shadow-lg dark:shadow-2xl text-center">
      <h2 class="text-xl md:text-2xl font-bold text-teal-900 dark:text-white mb-2">Coming Soon</h2>
      <p class="text-sm md:text-base text-teal-700 dark:text-gray-400">
        Settings and Account Management features will be added soon.
      </p>
    </div>
  </div>
</DashboardLayout>
