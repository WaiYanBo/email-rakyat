---
const rawPath = new URL(Astro.request.url).pathname;
const pathname = rawPath.replace(/\/$/, '') || '/';

const navLinks = [
  { name: 'Utama', path: '/' },
  { name: 'Tentang', path: '/tentang' },
  { name: 'Perkhidmatan', path: '/perkhidmatan' },
  { name: 'Berita', path: '/berita' },
  { name: 'Hubungi', path: '/hubungi' }
];
---

<header id="main-navbar" class="fixed w-full top-0 z-50 transition-all duration-300 ease-in-out bg-transparent py-5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center">
      
      <a href="/" class="flex-shrink-0 flex items-center gap-3 group">
        <img src="/Logo.webp" alt="Email Rakyat Logo" class="h-10 w-auto group-hover:scale-105 transition-transform duration-300" />
        <span class="text-white font-extrabold text-xl uppercase tracking-widest hidden sm:block group-hover:text-yellow-500 transition-colors">
          Email Rakyat
        </span>
      </a>

      <nav class="hidden md:flex space-x-8 items-center">
        {navLinks.map((link) => (
          <a 
            href={link.path} 
            class={`text-sm font-bold uppercase tracking-wider transition-colors duration-300 hover:text-yellow-400 ${
              pathname === link.path || (pathname === '/' + link.path.replace('/', '')) 
                ? 'text-yellow-500' 
                : 'text-gray-200'
            }`}
          >
            {link.name}
          </a>
        ))}
        <a
          href="/hubungi"
          class="inline-flex items-center rounded-full border border-yellow-500 bg-yellow-500 px-5 py-2 text-xs font-black uppercase tracking-wider text-black shadow-[0_0_20px_rgba(234,179,8,0.18)] transition-all duration-300 hover:scale-105 hover:bg-yellow-400"
        >
          Hubungi Segera
        </a>
      </nav>

      <div class="md:hidden flex items-center">
        <button id="mobile-menu-btn" type="button" aria-controls="mobile-menu" aria-expanded="false" aria-label="Toggle Menu" class="text-gray-200 hover:text-yellow-500 focus:outline-none transition-colors">
          <svg class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden absolute w-full bg-black/95 backdrop-blur-xl border-t border-gray-800 shadow-2xl">
    <div class="px-4 pt-2 pb-6 space-y-2 flex flex-col">
      {navLinks.map((link) => (
        <a 
          href={link.path} 
          class={`block px-3 py-3 rounded-lg text-base font-bold uppercase tracking-wide transition-colors ${
            pathname === link.path || (pathname === '/' + link.path.replace('/', '')) 
              ? 'bg-yellow-500/10 text-yellow-500' 
              : 'text-gray-300 hover:bg-gray-800 hover:text-yellow-400'
          }`}
        >
          {link.name}
        </a>
      ))}
      <a
        href="/hubungi"
        class="mt-2 block px-3 py-3 rounded-lg bg-yellow-500 text-center text-sm font-black uppercase tracking-wide text-black transition-colors hover:bg-yellow-400"
      >
        Hubungi Segera
      </a>
    </div>
  </div>
</header>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const navbar = document.getElementById('main-navbar');
    const mobileBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (!navbar || !mobileBtn || !mobileMenu) return;

    // Scroll Responsive Logic
    const handleScroll = () => {
      if (window.scrollY > 20) {
        // Scrolled state: frosted glass, shadow, smaller padding
        navbar.classList.remove('bg-transparent', 'py-5');
        navbar.classList.add('bg-black/80', 'backdrop-blur-md', 'shadow-lg', 'border-b', 'border-gray-800/60', 'py-3');
      } else {
        // Top state: transparent, larger padding
        navbar.classList.add('bg-transparent', 'py-5');
        navbar.classList.remove('bg-black/80', 'backdrop-blur-md', 'shadow-lg', 'border-b', 'border-gray-800/60', 'py-3');
      }
    };

    // Run on load to check initial scroll position
    handleScroll();

    // Listen for scroll events
    window.addEventListener('scroll', handleScroll);

    const syncMobileMenuBodyScroll = () => {
      const isOpen =
        !mobileMenu.classList.contains('hidden') && window.matchMedia('(max-width: 767px)').matches;
      document.body.style.overflow = isOpen ? 'hidden' : '';
    };

    // Mobile Menu Toggle Logic
    mobileBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      mobileMenu.classList.toggle('hidden');
      const expanded = !mobileMenu.classList.contains('hidden');
      mobileBtn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      syncMobileMenuBodyScroll();
    });

    window.addEventListener('resize', () => {
      if (window.matchMedia('(min-width: 768px)').matches) {
        document.body.style.overflow = '';
      } else {
        syncMobileMenuBodyScroll();
      }
    });

    // Close mobile menu when clicking outside
    document.addEventListener('click', (event) => {
      const target = event.target as Node;
      if (!navbar.contains(target) && !mobileMenu.classList.contains('hidden')) {
        mobileMenu.classList.add('hidden');
        mobileBtn.setAttribute('aria-expanded', 'false');
        syncMobileMenuBodyScroll();
      }
    });
  });
</script>